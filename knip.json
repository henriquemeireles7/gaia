{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignore": [".claude/**", ".gaia/**"],
  "tags": ["-public"],
  "workspaces": {
    ".": {
      "entry": ["drizzle.config.ts", "scripts/*.ts"]
    },
    "apps/api": {
      "entry": ["scripts/*.ts", "test/setup.ts"]
    },
    "apps/web": {
      "entry": [
        "src/entry-server.tsx",
        "src/entry-client.tsx",
        "src/app.tsx",
        "src/routes/**/*.{ts,tsx}",
        "src/components/index.ts",
        "app.config.ts"
      ]
    },
    "cli": {
      "entry": ["src/cli.ts", "src/create.ts", "src/preflight.ts", "test/**/*.test.ts"]
    }
  },
  "ignoreDependencies": ["@gaia/web"]
}
