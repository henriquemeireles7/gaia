{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignore": [".claude/**", ".gaia/**", "decisions/**", "tools/gritql/**"],
  "workspaces": {
    ".": {
      "entry": ["drizzle.config.ts", "scripts/*.ts"]
    },
    "apps/api": {
      "entry": ["scripts/*.ts", "test/setup.ts"]
    },
    "apps/web": {
      "entry": [
        "src/entry-server.tsx",
        "src/entry-client.tsx",
        "src/app.tsx",
        "src/routes/**/*.{ts,tsx}",
        "app.config.ts"
      ]
    }
  },
  "ignoreDependencies": ["@types/bun", "@gaia/api-server", "@gaia/security", "@gaia/web"]
}
