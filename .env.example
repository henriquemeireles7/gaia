# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED — App will not start without these
# ═══════════════════════════════════════════════════════════════════════════════

# Database — Postgres (Neon recommended, any Postgres works for dev)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gaia

# Auth — better-auth. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=dev-secret-change-in-production-min-32-chars

# App
NODE_ENV=development
PORT=3000
PUBLIC_APP_URL=http://localhost:3000

# Payments — Polar (merchant-of-record). https://polar.sh
POLAR_ACCESS_TOKEN=polar_at_xxx
POLAR_WEBHOOK_SECRET=polar_whsec_xxx
POLAR_PRODUCT_ID=prod_xxx

# Email — Resend. https://resend.com
RESEND_API_KEY=re_xxx

# AI — Anthropic. https://anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxx

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Features degrade gracefully without these
# ═══════════════════════════════════════════════════════════════════════════════

# Analytics — PostHog
# POSTHOG_API_KEY=phc_xxx
# POSTHOG_HOST=https://us.i.posthog.com
# PUBLIC_POSTHOG_KEY=phc_xxx

# Storage — Railway Buckets / S3 / R2 (S3-compatible)
# R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=xxx
# R2_SECRET_ACCESS_KEY=xxx
# R2_BUCKET_NAME=my-bucket

# OAuth — Google
# GOOGLE_CLIENT_ID=xxx
# GOOGLE_CLIENT_SECRET=xxx

# Observability — Sentry (errors)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Observability — Axiom (logs/traces/metrics)
# AXIOM_TOKEN=xxx
# AXIOM_ORG_ID=xxx

# Observability — OpenTelemetry exporter
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.example.com

# Workflows — Inngest
# INNGEST_EVENT_KEY=xxx
# INNGEST_SIGNING_KEY=xxx
