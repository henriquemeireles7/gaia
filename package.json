{
  "name": "gaia",
  "version": "0.1.0",
  "type": "module",
  "main": "apps/api/server/app.ts",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --hot apps/api/server/app.ts",
    "dev:web": "vinxi dev",
    "build": "bun build apps/api/server/app.ts --outdir dist --target bun --minify --external=isomorphic-dompurify",
    "build:web": "vinxi build",
    "start": "bun run dist/app.js",
    "check": "bun run check:lint && bun run check:types && bun run harden && bun run check:test",
    "check:lint": "bunx biome ci .",
    "check:types": "bunx tsc --noEmit",
    "check:test": "bun test --pass-with-no-tests",
    "harden": "bun packages/security/harden-check.ts",
    "test": "bun test",
    "lint": "bunx biome check --write --unsafe .",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bun apps/api/scripts/migrate.ts",
    "db:seed": "bun apps/api/scripts/seed.ts",
    "db:studio": "bunx drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@elysiajs/eden": "^1.1.3",
    "@hono/zod-validator": "^0.5.0",
    "@axiomhq/js": "^1.3.0",
    "@opentelemetry/api": "^1.9.0",
    "@polar-sh/sdk": "^0.20.0",
    "@sentry/node": "^9.0.0",
    "@sinclair/typebox": "^0.34.0",
    "@solidjs/router": "^0.15.0",
    "@solidjs/start": "^1.1.0",
    "@t3-oss/env-core": "^0.12.0",
    "better-auth": "^1.2.0",
    "drizzle-orm": "^0.38.0",
    "elysia": "^1.1.27",
    "gray-matter": "^4.0.3",
    "hono": "^4.7.0",
    "inngest": "^3.27.0",
    "isomorphic-dompurify": "^2.20.0",
    "marked": "^15.0.0",
    "posthog-node": "^4.4.0",
    "postgres": "^3.4.0",
    "preact": "^10.25.0",
    "preact-render-to-string": "^6.5.0",
    "resend": "^4.1.0",
    "solid-js": "^1.9.0",
    "stripe": "^17.5.0",
    "vinxi": "^0.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/bun": "latest",
    "drizzle-kit": "^0.30.0",
    "knip": "^5.40.0",
    "typescript": "^5.7.0"
  }
}
