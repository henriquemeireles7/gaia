{
  "name": "gaia",
  "version": "0.2.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "main": "apps/api/server/app.ts",
  "scripts": {
    "dev": "bun --hot apps/api/server/app.ts",
    "dev:web": "vinxi dev",
    "build": "bun build apps/api/server/app.ts --outdir dist --target bun --minify",
    "build:web": "vinxi build",
    "start": "bun run dist/app.js",
    "check": "bun run check:lint && bun run check:format && bun run check:ast && bun run check:types && bun run harden && bun run check:scripts && bun run check:test",
    "check:lint": "bunx oxlint .",
    "check:format": "bunx oxfmt --check .",
    "check:ast": "node_modules/.bin/ast-grep scan",
    "check:types": "bunx tsc --noEmit",
    "check:test": "bun test --pass-with-no-tests",
    "check:dead": "bunx knip --reporter compact",
    "check:scripts": "bun .gaia/rules/checks/check-rules-shards.ts && bun .gaia/rules/checks/check-skills.ts && bun .gaia/rules/checks/check-skill-triggers.ts && bun .gaia/rules/checks/validate-artifacts.ts && bun .gaia/rules/checks/check-tests-exist.ts && bun .gaia/rules/checks/check-tokens-sync.ts && bun .gaia/rules/checks/check-observability-init.ts && bun .gaia/rules/checks/check-marketing-vocab.ts && bun .gaia/rules/checks/check-integration-treaty.ts && bun .gaia/rules/checks/check-cli-stdout.ts && bun .gaia/rules/checks/check-reference-shape.ts && bun .gaia/rules/checks/check-reference-voice.ts && bun .gaia/rules/checks/check-reference-rule-mapping.ts && bun .gaia/rules/checks/check-reference-staleness.ts && bun .gaia/rules/checks/check-hook-determinism.ts && bun .gaia/rules/checks/check-migrations.ts && bun .gaia/rules/checks/check-typebox-derivation.ts",
    "rules:coverage": "bun .gaia/rules/checks/rules-coverage.ts",
    "tokens:generate": "bun scripts/generate-tokens-css.ts",
    "harden": "bun packages/security/harden-check.ts",
    "test": "bun test",
    "lint": "bunx oxlint --fix . && bunx oxfmt .",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bun apps/api/scripts/migrate.ts",
    "db:seed": "bun apps/api/scripts/seed.ts",
    "db:studio": "bunx drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@aws-sdk/client-s3": "^3.1038.0",
    "@aws-sdk/s3-request-presigner": "^3.1038.0",
    "@axiomhq/js": "^1.6.0",
    "@elysiajs/eden": "^1.4.9",
    "@gaia/adapters": "workspace:*",
    "@gaia/api-server": "workspace:*",
    "@gaia/auth": "workspace:*",
    "@gaia/config": "workspace:*",
    "@gaia/core": "workspace:*",
    "@gaia/db": "workspace:*",
    "@gaia/errors": "workspace:*",
    "@gaia/security": "workspace:*",
    "@gaia/ui": "workspace:*",
    "@gaia/web": "workspace:*",
    "@gaia/workflows": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "@polar-sh/sdk": "^0.47.1",
    "@sentry/node": "^10.50.0",
    "@sinclair/typebox": "^0.34.49",
    "@solidjs/router": "^0.16.1",
    "@solidjs/start": "^1.3.2",
    "better-auth": "^1.6.9",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "inngest": "^4.2.5",
    "postgres": "^3.4.9",
    "posthog-node": "^5.30.7",
    "resend": "^6.12.2",
    "solid-js": "^1.9.12",
    "vinxi": "^0.5.11"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.42.1",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "knip": "^6.8.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "fast-xml-parser": "^5.7.0",
    "h3": "^1.15.9",
    "hono": "^4.12.14",
    "uuid": "^14.0.0"
  },
  "trustedDependencies": [
    "@ast-grep/cli"
  ]
}
