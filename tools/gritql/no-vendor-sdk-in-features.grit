// tools/gritql/no-vendor-sdk-in-features.grit
//
// Enforces backend/no-vendor-sdk-in-features (vision §Architecture-2):
// feature code must go through @gaia/adapters, not vendor SDKs directly.
//
// Scoped to apps/api/features/** and apps/web/src/components|features|routes/**.
// Vendor SDKs to ban (must match @gaia/adapters mappings):
//   - @polar-sh/sdk → @gaia/adapters/payments
//   - @anthropic-ai/sdk → @gaia/adapters/ai
//   - resend → @gaia/adapters/email
//   - @aws-sdk/client-s3 → @gaia/adapters/storage
//   - posthog-node → @gaia/adapters/analytics

language js

`import $_ from "$source"` where {
  $source <: or {
    "@polar-sh/sdk",
    "@anthropic-ai/sdk",
    "resend",
    "@aws-sdk/client-s3",
    "@aws-sdk/s3-request-presigner",
    "posthog-node",
    "stripe"
  }
} => . then {
  register_diagnostic(
    span = $source,
    message = "Vendor SDK import is forbidden in feature code — go through @gaia/adapters/<capability>. See backend.md (rule backend/no-vendor-sdk-in-features).",
    severity = "error"
  )
}
