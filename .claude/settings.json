{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun run .claude/hooks/block-dangerous.ts"
          },
          {
            "type": "command",
            "command": "bun run .claude/hooks/pre-commit-check.ts"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bun run .claude/hooks/protect-files.ts"
          },
          {
            "type": "command",
            "command": "bun run .claude/hooks/protect-config.ts"
          },
          {
            "type": "command",
            "command": "bun run .claude/hooks/domain-context.ts"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/check-gstack.sh\""
          },
          {
            "type": "command",
            "command": "bun run .claude/hooks/skill-reference.ts"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun run .claude/hooks/warn-console-log.ts"
          },
          {
            "type": "command",
            "command": "bun run .claude/hooks/harden-gate.ts"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bun run .claude/hooks/reinject-context.ts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun run .claude/hooks/stop-quality-gate.ts"
          },
          {
            "type": "command",
            "command": "bun run .claude/hooks/update-context-files.ts"
          },
          {
            "type": "command",
            "command": "bun run .claude/hooks/notify-done.ts"
          }
        ]
      }
    ]
  }
}
